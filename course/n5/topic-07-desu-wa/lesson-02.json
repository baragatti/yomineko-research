      "type": "production",
      "prompt": {
        "pt-BR": "Aponte para algo que está perto de VOCÊ e pergunte 'O que é isto?' (forma polida, com は e ですか)."
      },
      "answer": {
        "text": "これは何ですか。",
        "accept": [
          "これは何ですか",
          "これはなんですか",
