  "exercises": [
    {
      "slug": "ex:n5-verbos-04-1",
      "type": "recognition",
      "prompt": "Qual é a forma EDUCADA (presente) do verbo irregular する?",
      "answer": {
        "choices": [
          "します",
          "すります",
          "しる"
        ],
        "correct": "します"
      },
      "explanation": "する é irregular: vira します no educado (não 'すります', que seguiria a regra dos verbos う). Decore: する → します.",
      "sentence_refs": []
    },
    {
      "slug": "ex:n5-verbos-04-2",
      "type": "cloze",
      "prompt": "Complete colando o verbo certo: este substantivo de ação vira verbo com する. けっこん＿ (casar-se)",
      "answer": {
        "text": "する",
        "full": "けっこんする"
      },
      "explanation": "結婚 (casamento) + する = 結婚する (casar-se). Muitos substantivos de ação viram verbos só grudando する atrás.",
      "sentence_refs": []
    },
    {
      "slug": "ex:n5-verbos-04-3",
      "type": "particle_choice",
      "prompt": "No sentido de CUSTAR, complete: このかばんは1万円＿する。 (Esta bolsa custa 10 mil ienes.)",
      "answer": {
        "choices": [
          "（nada）",
          "を",
          "が"
        ],
        "correct": "（nada）"
      },
      "explanation": "No uso 'custar', する é intransitiva e NÃO leva を: diz-se 1万円する, nunca 1万円をする. Por isso a lacuna fica vazia.",
      "sentence_refs": []
    },
    {
      "slug": "ex:n5-verbos-04-4",
      "type": "sentence_build",
      "prompt": "Monte 'Tiro uma cópia.' (educado) com as peças: [します] [を] [コピー]",
      "answer": {
        "order": [
          "コピー",
          "を",
          "します"
        ],
        "text": "コピーをします。"
      },
      "explanation": "コピー (cópia) + を + します (faço, educado) = コピーをします. Também valeria コピーします, sem o を; aqui praticamos a versão com を.",
      "sentence_refs": []
    },
    {
      "slug": "ex:n5-verbos-04-5",
      "type": "recognition",
      "prompt": "O que significa o kanji 時?",
      "answer": {
        "choices": [
          "tempo, hora",
          "pessoa",
          "dinheiro"
        ],
        "correct": "tempo, hora"
      },
      "explanation": "時 significa 'tempo / hora'. Leituras: とき (kun) e ジ (on, usada nas horas). Forma: 日 (sol/dia) + 寺 (templo).",
      "sentence_refs": []
    },
    {
      "slug": "ex:n5-verbos-04-6",
      "type": "production",
      "prompt": "Diga em japonês 'A aula acaba.' usando 授業 (aula), a partícula de sujeito が e o verbo 終わる no presente educado.",
      "answer": {
        "text": "授業が終わります。",
        "accept": [
          "授業が終わります",
          "じゅぎょうが終わります",
          "じゅぎょうがおわります",
          "授業がおわります"
        ]
      },
      "explanation": "授業 (aula) + が (sujeito) + 終わります (acaba, educado, de 終わる). Note que 終わる NÃO precisa de する: já é um verbo próprio.",
      "sentence_refs": []
    }
