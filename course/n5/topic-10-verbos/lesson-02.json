  "title": {
    "pt-BR": "Os verbos う (godan) e a partícula を"
  },
  "description": {
    "pt-BR": "Conhecemos a segunda grande família de verbos, os verbos う (godan), e usamos a partícula を para marcar o objeto direto que recebe a ação."
  },
  "objectives": [
    {
      "pt-BR": "Reconhecer um verbo う (godan) pela forma de dicionário terminada num som da coluna う"
    },
    {
      "pt-BR": "Usar a partícula を para marcar o objeto direto numa frase transitiva"
    },
    {
      "pt-BR": "Montar frases com verbos de ação frequentes (escrever, comprar, ouvir, lavar, dizer)"
    }
  ],
