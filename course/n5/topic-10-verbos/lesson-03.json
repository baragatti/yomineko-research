{
  "id": "les:n5-verbos-03",
  "schema_version": "1.0",
  "level": "n5",
  "topic": "top:n5-verbos",
  "order": 3,
  "title": {
    "pt-BR": "Ir e vir: verbos de deslocamento e o irregular くる"
  },
  "description": {
    "pt-BR": "Falamos de movimento: ir, voltar, andar, nadar e brincar. Apresentamos くる (vir), um dos dois únicos verbos irregulares do japonês, que indica deslocamento em direção a quem fala. O kanji 行 (ir) reforça o verbo 行く, e 中 (dentro/meio) e 長 (longo) complementam o conjunto."
  },
  "objectives": [
    {
      "pt-BR": "Usar verbos de deslocamento e atividade (いく, かえる, あるく, およぐ, あそぶ) no dia a dia"
    },
    {
      "pt-BR": "Conjugar o irregular くる à parte, percebendo que o radical muda de som (く/こ/き)"
    },
    {
      "pt-BR": "Escolher entre いく (ir, afasta-se) e くる (vir, aproxima-se) pelo ponto de vista de quem fala"
    },
    {
      "pt-BR": "Reconhecer os kanji 行, 中 e 長 e ligá-los a palavras que você já usa"
    }
  ],
