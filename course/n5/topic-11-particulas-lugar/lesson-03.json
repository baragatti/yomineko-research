  "exercises": [
    {
      "slug": "ex:n5-particulas-lugar-03-1",
      "type": "recognition",
      "prompt": "Qual partícula marca o LUGAR ONDE UMA AÇÃO ACONTECE (ex.: estudar na escola)?",
      "answer": {
        "choices": [
          "で",
          "に",
          "は"
        ],
        "correct": "で"
      },
      "explanation": "で marca o palco da ação: 学校で勉強する ('estudar na escola'). Já に marca onde algo apenas existe (学校にいる, 'estar na escola').",
      "sentence_refs": []
    },
    {
      "slug": "ex:n5-particulas-lugar-03-2",
      "type": "particle_choice",
      "prompt": "Complete: レストラン＿食べます。 (Como/almoço no restaurante.)",
      "answer": {
        "choices": [
          "で",
          "に",
          "へ"
        ],
        "correct": "で"
      },
      "explanation": "食べる é uma ação, então o lugar onde ela acontece leva で. に aqui daria 'existir no restaurante', que não é o que se quer dizer.",
      "sentence_refs": []
    },
    {
      "slug": "ex:n5-particulas-lugar-03-3",
      "type": "particle_choice",
      "prompt": "Complete: 大学＿います。 (Estou na faculdade.)",
      "answer": {
        "choices": [
          "に",
          "で",
          "を"
        ],
        "correct": "に"
      },
      "explanation": "います (いる) é existência/presença, não ação: por isso usa に. Se fosse 大学で勉強する ('estudar na faculdade'), aí sim seria で. Esse é o contraste central da lição.",
      "sentence_refs": []
    },
    {
      "slug": "ex:n5-particulas-lugar-03-4",
      "type": "cloze",
      "prompt": "Complete com a partícula de meio de transporte: タクシー＿行きます。 (Vou de táxi.)",
      "answer": {
        "text": "で",
        "full": "タクシーで行きます"
      },
      "explanation": "で também marca o meio pelo qual a ação é feita, incluindo transporte: タクシーで ('de táxi'), 電車で ('de trem'). É o mesmo で de 'por meio de'.",
      "sentence_refs": []
    },
    {
      "slug": "ex:n5-particulas-lugar-03-5",
      "type": "sentence_build",
      "prompt": "Monte 'Limpo (faço limpeza) em casa.' com as peças: [掃除します] [家] [で]",
      "answer": {
        "order": [
          "家",
          "で",
          "掃除します"
        ],
        "text": "家で掃除します。"
      },
      "explanation": "Lugar + で + ação: 家 (casa) + で (onde a ação acontece) + 掃除します (faço limpeza). 掃除 vira verbo com する/します.",
      "sentence_refs": []
    },
    {
      "slug": "ex:n5-particulas-lugar-03-6",
      "type": "production",
      "prompt": "Diga em japonês 'Estudo na escola.' usando 学校 (escola), a partícula de lugar da ação e 勉強します (estudo).",
      "answer": {
        "text": "学校で勉強します。",
        "accept": [
          "学校で勉強します",
          "がっこうで勉強します",
          "がっこうでべんきょうします",
          "学校でべんきょうします"
        ]
      },
      "explanation": "学校 (escola) + で (lugar da ação) + 勉強します (estudo). Como estudar é uma ação, o lugar leva で e não に.",
      "sentence_refs": []
    }
