  "exercises": [
    {
      "id": "ex:n5-particulas-lugar-08-1",
      "type": "recognition",
      "prompt": {
        "pt-BR": "Qual é a diferença entre 本とペン e 本やペン?"
      },
      "answer": {
        "choices": [
          "と = lista fechada (só livro e caneta); や = exemplos (livro, caneta, entre outros)",
          "São idênticos; と e や são intercambiáveis",
          "と = exemplos; や = lista fechada"
        ],
        "correct": "と = lista fechada (só livro e caneta); や = exemplos (livro, caneta, entre outros)"
      },
      "explanation": {
        "pt-BR": "と lista de forma completa e fechada ('apenas estes itens'); や cita só alguns exemplos e deixa subentendido que há mais ('entre outros')."
      },
      "sentence_refs": [
        "sent:gen-2293f3cce26e"
      ]
    },
    {
      "id": "ex:n5-particulas-lugar-08-2",
      "type": "particle_choice",
      "prompt": {
        "pt-BR": "Em cima da mesa tem livros, canetas E COISAS ASSIM (exemplos): 机の上に本＿ペンがある。"
      },
      "answer": {
        "choices": [
          "や",
          "と",
          "だけ"
        ],
        "correct": "や"
      },
      "explanation": {
        "pt-BR": "'E coisas assim' = lista de exemplos = や. Com と a frase diria que há exatamente livros e canetas, nada mais."
      },
      "sentence_refs": [
        "sent:gen-2293f3cce26e"
      ]
    },
    {
      "id": "ex:n5-particulas-lugar-08-3",
      "type": "particle_choice",
      "prompt": {
        "pt-BR": "Para dizer 'trabalho ATÉ as cinco horas': 五時＿働きます。"
      },
      "answer": {
        "choices": [
          "まで",
          "だけ",
          "と"
        ],
        "correct": "まで"
      },
      "explanation": {
        "pt-BR": "まで marca o ponto final no tempo: 五時まで = 'até as cinco horas'. だけ ('só') daria 'só as cinco horas', outro sentido."
      },
      "sentence_refs": []
    },
    {
      "id": "ex:n5-particulas-lugar-08-4",
      "type": "cloze",
      "prompt": {
        "pt-BR": "Complete para dizer 'só cinco minutos' (apenas): 五分＿。"
      },
      "answer": {
        "text": "だけ",
        "full": "五分だけ"
      },
      "explanation": {
        "pt-BR": "だけ marca limite/exclusividade: 五分だけ = 'apenas cinco minutos'. 五 lê-se ご em 五分 (ごふん)."
      },
      "sentence_refs": []
    },
    {
      "id": "ex:n5-particulas-lugar-08-5",
      "type": "sentence_build",
      "prompt": {
        "pt-BR": "Monte 'Vou com você (essa pessoa).' com as peças: [行きます] [そちら] [と]"
      },
      "answer": {
        "order": [
          "そちら",
          "と",
          "行きます"
        ],
        "text": "そちらと行きます。"
      },
      "explanation": {
        "pt-BR": "Junto a um verbo de ação, と significa 'com' (companhia): そちら (você/essa pessoa) + と (com) + 行きます (vou)."
      },
      "sentence_refs": []
    },
    {
      "id": "ex:n5-particulas-lugar-08-6",
      "type": "production",
      "prompt": {
        "pt-BR": "Diga em japonês 'Bebo só água.' (use 水 = água, a partícula de exclusividade e 飲みます = bebo)."
      },
      "answer": {
        "text": "水だけ飲みます。",
        "accept": [
          "水だけ飲みます",
          "みずだけ飲みます",
          "みずだけのみます",
          "水だけのみます"
        ]
