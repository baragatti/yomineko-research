  "exercises": [
    {
      "id": "ex:n5-particulas-lugar-06-1",
      "type": "recognition",
      "prompt": {
        "pt-BR": "O que a frase ひるごはんを食べに行きます expressa?"
      },
      "answer": {
        "choices": [
          "Vou (sair) para almoçar",
          "Estou almoçando agora",
          "Não vou almoçar"
        ],
        "correct": "Vou (sair) para almoçar"
      },
      "explanation": {
        "pt-BR": "食べ (raiz de 食べる) + に行きます marca a finalidade da ida: 'ir a fim de comer'. Com ひるごはん (almoço), o natural em pt-BR é 'vou almoçar'."
      },
      "sentence_refs": [
        "sent:gen-59bccb81087b"
      ]
    },
    {
      "id": "ex:n5-particulas-lugar-06-2",
      "type": "particle_choice",
      "prompt": {
        "pt-BR": "Complete para dizer 'vou ver um filme': 映画を見＿行きます。"
      },
      "answer": {
        "choices": [
          "に",
          "で",
          "を"
        ],
        "correct": "に"
      },
      "explanation": {
        "pt-BR": "Na construção 〜に行く, a partícula に liga o objetivo (見, raiz de 見る = ver) ao verbo de movimento. Aqui ela marca finalidade, não destino."
      },
      "sentence_refs": []
    },
    {
      "id": "ex:n5-particulas-lugar-06-3",
      "type": "cloze",
      "prompt": {
        "pt-BR": "Complete com o dia certo: 水曜日と＿は学校に行きます。 (Vou à escola na quarta e na sexta.); escreva a sexta-feira em kana."
      },
      "answer": {
        "text": "きんようび",
        "full": "水曜日ときんようびは学校に行きます。"
      },
      "explanation": {
        "pt-BR": "金曜日 (きんようび) = sexta-feira. Todos os dias terminam em 曜日 (ようび). Aqui 学校に行く usa o に de destino ('ir À escola'), diferente do に de finalidade."
      },
      "sentence_refs": []
    },
    {
      "id": "ex:n5-particulas-lugar-06-4",
      "type": "sentence_build",
      "prompt": {
        "pt-BR": "Monte 'Se o tempo estiver bom, a gente vai fazer uma trilha.' com as peças: [ハイキングに] [天気が] [行く] [よければ]"
      },
      "answer": {
        "order": [
          "天気が",
          "よければ",
          "ハイキングに",
          "行く"
        ],
        "text": "天気がよければハイキングに行く"
      },
