{
  "id": "les:n5-particulas-lugar-06",
  "schema_version": "1.0",
  "level": "n5",
  "topic": "top:n5-particulas-lugar",
  "order": 6,
  "title": {
    "pt-BR": "Ir com um objetivo: 〜に行く"
  },
  "description": {
    "pt-BR": "Construção que expressa o propósito de um deslocamento: ir a algum lugar a fim de fazer algo (\"ir almoçar\", \"ir ver um filme\"). A partícula に aqui marca a finalidade da ida e funciona também com 来る (vir) e 帰る (voltar)."
  },
  "objectives": [
    {
      "pt-BR": "Expressar o objetivo de uma ida com a construção 〜に行く (ir fazer algo)"
    },
    {
      "pt-BR": "Montar 〜に行く tanto com a raiz do verbo (食べに行く) quanto com substantivo de ação (ハイキングに行く)"
    },
    {
      "pt-BR": "Estender o padrão para 来る (vir) e 帰る (voltar)"
    },
    {
      "pt-BR": "Nomear os dias da semana em japonês (月曜日, 火曜日, 水曜日, 金曜日)"
    }
  ],
