  "exercises": [
    {
      "slug": "ex:n5-particulas-lugar-02-1",
      "type": "recognition",
      "prompt": "Na frase 人がいる ('Há pessoas.'), por que o verbo é いる e não ある?",
      "answer": {
        "choices": [
          "Porque 人 (pessoa) é um ser vivo",
          "Porque いる é mais educado que ある",
          "Porque a frase está no plural"
        ],
        "correct": "Porque 人 (pessoa) é um ser vivo"
      },
      "explanation": "O japonês escolhe o verbo de existência pela natureza do sujeito: いる para seres vivos (gente, bicho) e ある para coisas. Como 人 é pessoa, usa-se いる.",
      "sentence_refs": [
        "sent:tatoeba-6828199"
      ]
    },
    {
      "slug": "ex:n5-particulas-lugar-02-2",
      "type": "cloze",
      "prompt": "Complete com o verbo de existência casual certo: 嵐のきざしが＿。 ('Há sinais de tempestade.')",
      "answer": {
        "text": "ある",
        "full": "嵐のきざしがある"
      },
      "explanation": "きざし (sinal/indício) é uma coisa abstrata, não um ser vivo, então o verbo é ある (forma casual). A versão educada seria あります.",
      "sentence_refs": [
        "sent:tatoeba-78451"
      ]
    },
    {
      "slug": "ex:n5-particulas-lugar-02-3",
      "type": "particle_choice",
      "prompt": "Qual partícula marca o LUGAR onde algo existe? そこ＿ネコがいる。 ('Tem um gato aí.')",
      "answer": {
        "choices": [
          "に",
          "で",
          "が"
        ],
        "correct": "に"
      },
      "explanation": "Com ある/いる o lugar da existência vem marcado por に (não で). で marcaria o lugar de uma AÇÃO; aqui só dizemos onde o gato ESTÁ.",
      "sentence_refs": []
    },
    {
      "slug": "ex:n5-particulas-lugar-02-4",
      "type": "sentence_build",
      "prompt": "Monte 'Tem um cachorro lá fora.' com as peças: [いる] [外] [犬] [に] [が]",
      "answer": {
        "order": [
          "外",
          "に",
          "犬",
          "が",
          "いる"
        ],
        "text": "外に犬がいる。"
      },
      "explanation": "Molde lugar に + ser が + いる: 外 (fora) + に (lugar) + 犬 (cachorro) + が + いる. Cachorro é ser vivo, por isso いる, e na forma casual.",
      "sentence_refs": []
    },
    {
      "slug": "ex:n5-particulas-lugar-02-5",
      "type": "production",
      "prompt": "Diga em japonês, no registro casual, 'Tem alguém aí.' (use そこ, に, 誰か e o verbo certo).",
      "answer": {
        "text": "そこに誰かいる。",
        "accept": [
          "そこに誰かいる",
          "そこにだれかいる",
          "そこに誰かがいる",
          "そこにだれかがいる"
        ]
      },
      "explanation": "そこ (aí) + に (lugar) + 誰か (alguém) + いる (existência de ser vivo, forma casual). Como 誰か é pessoa, o verbo só pode ser いる; が depois de 誰か é opcional na fala.",
      "sentence_refs": []
    }
