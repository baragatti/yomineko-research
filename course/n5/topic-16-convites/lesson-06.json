  "exercises": [
    {
      "id": "ex:n5-convites-06-1",
      "type": "recognition",
      "prompt": {
        "pt-BR": "O que significa o verbo 降る (ふる)?"
      },
      "answer": {
        "choices": [
          "soprar (o vento)",
          "cair (chuva, neve)",
          "dobrar / virar"
        ],
        "correct": "cair (chuva, neve)"
      },
      "explanation": {
        "pt-BR": "降る (ふる) é o verbo para algo que cai do céu: chuva, neve, cinzas. Não confunda com 吹く (ふく), 'soprar (o vento)'."
      },
      "sentence_refs": []
    },
    {
      "id": "ex:n5-convites-06-2",
      "type": "recognition",
      "prompt": {
        "pt-BR": "Qual palavra você usa para dizer 'por aqui / esta região'?"
      },
      "answer": {
        "choices": [
          "辺 (へん)",
          "本当 (ほんとう)",
          "ひる"
        ],
        "correct": "辺 (へん)"
      },
      "explanation": {
        "pt-BR": "辺 (へん) significa área, arredores, região. この辺 = 'por aqui'. 本当 é 'verdade' e ひる é 'meio-dia'."
      },
      "sentence_refs": []
    },
    {
      "id": "ex:n5-convites-06-3",
      "type": "cloze",
      "prompt": {
        "pt-BR": "Complete com o verbo certo: 雨が＿。 (Vai chover / A chuva cai.) Use a forma de dicionário em kana."
      },
      "answer": {
        "text": "ふる",
        "full": "雨がふる"
      },
      "explanation": {
        "pt-BR": "雨 (あめ, chuva) anda com 降る (ふる). A chuva 'cai': 雨が降る. Lembre que o vento, esse sim, 'sopra' (吹く / ふく)."
      },
      "sentence_refs": []
    },
    {
      "id": "ex:n5-convites-06-4",
      "type": "particle_choice",
      "prompt": {
        "pt-BR": "Complete: 風＿吹く。 (O vento sopra.) Qual partícula marca quem faz a ação?"
      },
      "answer": {
        "choices": [
          "が",
          "は",
          "を"
        ],
        "correct": "が"
      },
      "explanation": {
        "pt-BR": "Nas frases de clima, が marca quem faz a ação: 風が吹く ('o vento sopra'), assim como 雨が降る ('a chuva cai')."
      },
      "sentence_refs": []
    },
    {
      "id": "ex:n5-convites-06-5",
      "type": "production",
      "prompt": {
        "pt-BR": "Diga em japonês 'Quero água.' usando 水 (みず, água), a partícula が e o adjetivo 'querer (ter)'."
      },
      "answer": {
        "text": "水が欲しい。",
        "accept": [
          "水が欲しい",
          "みずが欲しい",
          "みずがほしい",
          "水がほしい"
        ]
      },
      "explanation": {
        "pt-BR": "欲しい (ほしい) é um adjetivo, não um verbo: 水が欲しい = 'quero água'. O objeto desejado vem marcado por が."
      },
      "sentence_refs": []
    }
