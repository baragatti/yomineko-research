  "exercises": [
    {
      "id": "ex:n5-rotina-03-1",
      "type": "recognition",
      "prompt": {
        "pt-BR": "Qual estrutura significa \"DEPOIS de fazer\" (uma ação termina e então vem a próxima)?"
      },
      "answer": {
        "choices": [
          "〜まえに",
          "〜てから",
          "〜です"
        ],
        "correct": "〜てから"
      },
      "explanation": {
        "pt-BR": "〜てから (forma て + から) marca que algo acontece DEPOIS de outra ação terminar. 〜まえに é o oposto: \"antes de\"."
      },
      "sentence_refs": []
    },
    {
      "id": "ex:n5-rotina-03-2",
      "type": "cloze",
      "prompt": {
        "pt-BR": "Complete com a partícula que forma \"antes de dormir\": 寝る＿に歯を磨きます。 (Antes de dormir, escovo os dentes.)"
      },
      "answer": {
        "text": "まえ",
        "full": "寝るまえに歯を磨きます"
      },
      "explanation": {
        "pt-BR": "O verbo 寝る fica no dicionário e recebe まえに = \"antes de dormir\". O verbo antes de まえに nunca muda de tempo."
      },
      "sentence_refs": [
        "sent:gen-1ae4a3cf896d"
      ]
    },
    {
      "id": "ex:n5-rotina-03-3",
      "type": "particle_choice",
      "prompt": {
        "pt-BR": "Escolha o conector para \"depois de apagar a luz, durmo\": 電気を消し＿寝ます。"
      },
      "answer": {
        "choices": [
          "てから",
          "まえに",
          "です"
        ],
        "correct": "てから"
      },
      "explanation": {
        "pt-BR": "消す vira a forma て 消して; juntando から temos 消してから = \"depois de apagar (a luz)\". A primeira ação termina, então vem dormir."
      },
      "sentence_refs": []
    },
    {
      "id": "ex:n5-rotina-03-4",
      "type": "sentence_build",
      "prompt": {
        "pt-BR": "Monte 'Antes de sair, apago a luz.' com as peças: [まえに] [出かける] [電気を] [消します]"
      },
      "answer": {
        "order": [
          "出かける",
          "まえに",
          "電気を",
          "消します"
        ],
        "text": "出かけるまえに電気を消します。"
      },
      "explanation": {
        "pt-BR": "出かける (sair, no dicionário) + まえに (antes de) + 電気を消します (apago a luz). O \"antes de\" vem primeiro; a ação principal fecha a frase."
      },
      "sentence_refs": [
        "sent:gen-ac0e695fa395"
      ]
    },
    {
      "id": "ex:n5-rotina-03-5",
      "type": "production",
      "prompt": {
        "pt-BR": "Diga em japonês 'Depois de jantar (夕飯), descanso.' usando 〜てから e o verbo 休みます (descansar)."
      },
      "answer": {
        "text": "夕飯を食べてから休みます。",
        "accept": [
          "夕飯を食べてから休みます",
          "夕飯を食べてから休みます。",
          "ゆうはんを食べてから休みます",
          "夕飯をたべてからやすみます",
          "ゆうはんをたべてからやすみます"
        ]
      },
      "explanation": {
        "pt-BR": "夕飯を食べる (jantar) vira 食べてから (depois de jantar) + 休みます (descanso). A forma て + から coloca o descanso DEPOIS da refeição."
      },
