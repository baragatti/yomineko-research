{
  "id": "les:n5-rotina-03",
  "schema_version": "1.0",
  "level": "n5",
  "topic": "top:n5-rotina",
  "order": 3,
  "title": {
    "pt-BR": "Antes e depois: 〜まえに e 〜てから"
  },
  "description": {
    "pt-BR": "Coloque sua rotina em ordem no tempo. 〜まえに (\"antes de\") e 〜てから (\"depois de fazer\") encadeiam ações; escovar os dentes antes de dormir, sair depois de apagar a luz. O vocabulário reúne verbos de rotina e adjetivos do cotidiano para descrever o dia."
  },
  "objectives": [
    {
      "pt-BR": "Dizer que uma ação acontece antes de outra com 〜まえに (verbo no dicionário + まえに)"
    },
    {
      "pt-BR": "Dizer que uma ação acontece depois de outra com 〜てから (forma て + から)"
    },
    {
      "pt-BR": "Sequenciar a própria rotina escolhendo entre 〜まえに e 〜てから"
    }
  ],
