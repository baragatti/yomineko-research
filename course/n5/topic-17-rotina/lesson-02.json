    {
      "slug": "ex:n5-rotina-02-1",
      "type": "recognition",
      "prompt": "Na frase もうお金がありません ('Já não tenho mais dinheiro'), o que もう significa aqui, junto do verbo negativo ありません?",
      "answer": {
        "choices": [
          "já (concluído)",
          "não... mais / já não",
          "ainda"
        ],
        "correct": "não... mais / já não"
      },
      "explanation": "Com verbo afirmativo, もう = 'já'. Mas com verbo NEGATIVO (ありません = não há), もう vira 'não... mais / já não'. Por isso a frase é 'já não tenho mais dinheiro'.",
      "sentence_refs": [
        "sent:gen-ffc42666e4f4"
      ]
    },
    {
      "slug": "ex:n5-rotina-02-2",
      "type": "cloze",
      "prompt": "Complete com 'já': ＿食べました。 (Já comi.)",
      "answer": {
        "text": "もう",
        "full": "もう食べました"
      },
      "explanation": "もう ('já') vai no começo e o verbo fica no passado (食べました). Indica que a ação já aconteceu.",
      "sentence_refs": []
    },
    {
      "slug": "ex:n5-rotina-02-3",
