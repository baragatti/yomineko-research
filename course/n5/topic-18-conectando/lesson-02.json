{
  "id": "les:n5-conectando-02",
  "schema_version": "1.0",
  "level": "n5",
  "topic": "top:n5-conectando",
  "order": 2,
  "title": {
    "pt-BR": "Contrastar: けど, だけど e けれども"
  },
  "description": {
    "pt-BR": "A família de conectores adversativos けど／だけど／けれども (\"mas, embora\"), do mais casual ao mais formal."
  },
  "objectives": [
    {
      "pt-BR": "Ligar duas ideias por contraste com けど ('mas', 'só que') no fim da primeira oração"
    },
    {
      "pt-BR": "Escolher entre けど, だけど e けれども conforme a palavra anterior e o nível de formalidade"
    },
    {
      "pt-BR": "Usar けど para suavizar uma fala ou deixá-la em aberto, sem soar incompleto"
    },
    {
      "pt-BR": "Descrever pessoas e coisas com adjetivos novos (ゆうめい, わかい, よわい, わるい, りっぱ, いい)"
    }
  ],
