{
  "id": "les:n5-conectando-03",
  "schema_version": "1.0",
  "level": "n5",
  "topic": "top:n5-conectando",
  "order": 3,
  "title": {
    "pt-BR": "Encadear ideias: でも, しかし, そして, それから"
  },
  "description": {
    "pt-BR": "Conecte frases inteiras: でも e しかし para marcar contraste no início da frase (\"mas\", \"porém\", \"contudo\"), そして e それから para acrescentar ou sequenciar (\"e\", \"e então\", \"e depois disso\"). Vocabulário de lugares do dia a dia(correios, restaurante, geladeira, corredor, banho) e o conectivo そうして."
  },
  "objectives": [
    {
      "pt-BR": "Marcar contraste entre duas frases com でも e しかし no início da segunda frase"
    },
    {
      "pt-BR": "Acrescentar ou sequenciar ideias com そして (e / e então) e それから (e depois disso)"
    },
    {
      "pt-BR": "Distinguir conectivos de contraste (でも/しかし) dos de adição/sequência (そして/それから)"
    },
    {
      "pt-BR": "Reconhecer o kanji 休 (descanso) e ler vocabulário de lugares do dia a dia"
    }
  ],
