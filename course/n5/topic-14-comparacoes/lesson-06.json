{
  "id": "les:n5-comparacoes-06",
  "schema_version": "1.0",
  "level": "n5",
  "topic": "top:n5-comparacoes",
  "order": 6,
  "title": {
    "pt-BR": "Em excesso: ～すぎる"
  },
  "description": {
    "pt-BR": "Quando algo passa do ponto: ～すぎる (\"demais\", \"em excesso\"), tanto para ações feitas em demasia quanto para qualidades exageradas (caro demais, grande demais). Fecha o tópico revisando adjetivos e ações já vistos sob a ótica do exagero."
  },
  "objectives": [
    {
      "pt-BR": "Formar ～すぎる a partir de verbos (raiz da forma ます) e de adjetivos (sem o い / sem o な)"
    },
    {
      "pt-BR": "Indicar excesso em uma AÇÃO (comer demais, beber demais) com 〜すぎる"
    },
    {
      "pt-BR": "Indicar uma qualidade EXAGERADA (caro demais, grande demais) com 〜すぎる"
    },
    {
      "pt-BR": "Distinguir すぎる (exagero indesejado) de とても (\"muito\", neutro)"
    }
  ],
