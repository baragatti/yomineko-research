  "exercises": [
    {
      "id": "ex:n5-numeros-tempo-02-1",
      "type": "recognition",
      "prompt": {
        "pt-BR": "Na série genérica つ, qual é a leitura de 五つ (cinco)?"
      },
      "answer": {
        "choices": [
          "いつつ",
          "ごつ",
          "ここのつ"
        ],
        "correct": "いつつ"
      },
      "explanation": {
        "pt-BR": "Na série つ o 5 lê-se いつつ (não 'ご' como no número solto). ここのつ é o 9. A série tem leitura própria, do japonês antigo."
      },
      "sentence_refs": []
    },
    {
      "id": "ex:n5-numeros-tempo-02-2",
      "type": "cloze",
      "prompt": {
        "pt-BR": "Complete para dizer 'cerca de mil pessoas': 千人＿の人がいた。"
      },
      "answer": {
        "text": "くらい",
        "full": "千人くらいの人がいた。"
      },
      "explanation": {
        "pt-BR": "Número/quantidade + くらい = aproximação. 千人くらい = 'cerca de mil pessoas'. A frase inteira é 'Havia cerca de mil pessoas.'"
      },
      "sentence_refs": [
        "sent:tatoeba-141433"
      ]
    },
    {
      "id": "ex:n5-numeros-tempo-02-3",
      "type": "particle_choice",
      "prompt": {
        "pt-BR": "Para distribuir 'um de cada / um por um', que peça entra? 一つ＿ください。"
      },
      "answer": {
        "choices": [
          "ずつ",
          "くらい",
          "ごろ"
        ],
        "correct": "ずつ"
      },
      "explanation": {
        "pt-BR": "ずつ dá a ideia de 'cada / por unidade': 一つずつ = 'um de cada'. くらい seria aproximação ('uns'), e ごろ é só para pontos no tempo (horários/datas)."
      },
      "sentence_refs": []
    },
    {
      "id": "ex:n5-numeros-tempo-02-4",
      "type": "sentence_build",
      "prompt": {
        "pt-BR": "Monte 'Comi uns dois.' com as peças: [食べました] [二つ] [くらい]"
      },
      "answer": {
        "order": [
          "二つ",
          "くらい",
          "食べました"
        ],
        "text": "二つくらい食べました。"
      },
      "explanation": {
        "pt-BR": "二つ (dois, série つ) + くらい (uns/cerca de) + 食べました (comi). O くらい vem logo depois do número para dar a ideia de quantidade aproximada."
      },
      "sentence_refs": []
    },
    {
      "id": "ex:n5-numeros-tempo-02-5",
      "type": "production",
      "prompt": {
        "pt-BR": "Diga em japonês 'cerca de dez milhões de ienes' usando 一千万円 (dez milhões de ienes) + a partícula de aproximação."
      },
      "answer": {
        "text": "一千万円くらい",
