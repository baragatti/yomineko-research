  "exercises": [
    {
      "id": "ex:n5-numeros-tempo-05-1",
      "type": "recognition",
      "prompt": {
        "pt-BR": "O que significa 時間 (じかん)?"
      },
      "answer": {
        "choices": [
          "tempo / hora(s) de duração",
          "semana",
          "mês"
        ],
        "correct": "tempo / hora(s) de duração"
      },
      "explanation": {
        "pt-BR": "時間 (じかん) é 'tempo'; em contagem vira a duração em horas (ex.: さんじかん = três horas de duração). Semana é 週間 e mês é ヶ月."
      },
      "sentence_refs": []
    },
    {
      "id": "ex:n5-numeros-tempo-05-2",
      "type": "recognition",
      "prompt": {
        "pt-BR": "Como se LÊ a data ９日 (dia 9 do mês)?"
      },
      "answer": {
        "choices": [
          "ここのか",
          "きゅうにち",
          "くにち"
        ],
        "correct": "ここのか"
      },
      "explanation": {
        "pt-BR": "Os dias 1 a 10 têm leituras especiais. '9 do mês' é ここのか, não 'kyuunichi'. Decore como palavra inteira; o kanji 日 aqui se lê か."
      },
      "sentence_refs": []
    },
    {
      "id": "ex:n5-numeros-tempo-05-3",
      "type": "cloze",
      "prompt": {
        "pt-BR": "Complete para dizer 'passou das três (pouco depois das 3)': さんじ＿。"
      },
      "answer": {
        "text": "すぎ",
        "full": "さんじすぎ"
      },
      "explanation": {
        "pt-BR": "過ぎ (すぎ) = 'passado / depois de', colado depois da hora cheia: さんじ + すぎ = 'passou das três'."
      },
      "sentence_refs": []
    },
    {
