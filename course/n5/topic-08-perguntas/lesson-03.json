  "exercises": [
    {
      "id": "ex:n5-perguntas-03-1",
      "type": "recognition",
      "prompt": {
        "pt-BR": "Há cinco câmeras na vitrine e você quer perguntar 'qual deles?' SEM dizer a palavra 'câmera'. Qual palavra usar?"
      },
      "answer": {
        "choices": [
          "どれ",
          "どの",
          "どこ"
        ],
        "correct": "どれ"
      },
      "explanation": {
        "pt-BR": "Sem o nome depois e com três ou mais opções, usa-se どれ ('qual deles?'). どの precisaria de um substantivo logo após."
      },
      "sentence_refs": []
    },
    {
      "id": "ex:n5-perguntas-03-2",
      "type": "recognition",
      "prompt": {
        "pt-BR": "O que diferencia どれ de どの?"
      },
      "answer": {
        "choices": [
          "どの vem antes de um substantivo; どれ fica sozinho",
          "São idênticos",
          "どれ é mais formal que どの"
        ],
        "correct": "どの vem antes de um substantivo; どれ fica sozinho"
      },
      "explanation": {
        "pt-BR": "どの sempre acompanha um nome (どの車 = qual carro); どれ é o pronome que fica sozinho (どれ = qual deles)."
      },
      "sentence_refs": []
    },
    {
      "id": "ex:n5-perguntas-03-3",
      "type": "cloze",
      "prompt": {
        "pt-BR": "Complete dizendo 'qual carro?' (o nome 車 aparece): ＿＿車ですか。"
      },
      "answer": {
        "text": "どの",
        "full": "どの車ですか"
      },
      "explanation": {
        "pt-BR": "Como o nome 車 (くるま, carro) aparece logo depois, usa-se どの + nome. どれ車 estaria errado."
      },
      "sentence_refs": []
    },
    {
