    {
      "id": "ex:n5-adjetivos-03-2",
      "type": "cloze",
      "prompt": {
        "pt-BR": "Complete o negativo informal de 忙しい (いそがしい, 'ocupado'): 今日は忙し＿。 (Hoje não estou ocupado.)"
