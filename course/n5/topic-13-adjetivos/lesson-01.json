{
  "id": "les:n5-adjetivos-01",
  "schema_version": "1.0",
  "level": "n5",
  "topic": "top:n5-adjetivos",
  "order": 1,
  "title": {
    "pt-BR": "Adjetivos い e な: o básico para descrever"
  },
  "description": {
    "pt-BR": "As duas grandes classes de adjetivos do japonês. Você aprende a reconhecer um adjetivo-い (termina em い e já carrega tempo) e um adjetivo-な (comporta-se quase como substantivo), além de intensificar qualquer descrição com とても (muito). Começamos com cores e qualidades simples para descrever pessoas e coisas no presente afirmativo."
  },
  "objectives": [
    {
      "pt-BR": "Reconhecer um adjetivo-い pela terminação em い e entender que ele já carrega o tempo da frase"
    },
    {
      "pt-BR": "Reconhecer um adjetivo-な e perceber que ele se comporta quase como um substantivo"
    },
    {
      "pt-BR": "Descrever cores e qualidades básicas no presente afirmativo, com e sem です"
    },
    {
      "pt-BR": "Intensificar uma descrição com o advérbio とても (muito)"
    }
  ],
