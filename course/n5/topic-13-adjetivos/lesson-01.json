  "exercises": [
    {
      "id": "ex:n5-adjetivos-01-1",
      "type": "recognition",
      "prompt": {
        "pt-BR": "Qual destas palavras é um adjetivo-い (termina em い na forma de dicionário)?"
      },
      "answer": {
        "choices": [
          "きれい",
          "おおきい",
          "しずか"
        ],
        "correct": "おおきい"
      },
      "explanation": {
        "pt-BR": "おおきい (大きい, 'grande') termina em い de verdade: é adjetivo-い. Cuidado com きれい: ela tem o som 'i' no fim, mas é adjetivo-な disfarçado. しずか é claramente adjetivo-な."
      },
      "sentence_refs": []
    },
    {
      "id": "ex:n5-adjetivos-01-2",
      "type": "recognition",
      "prompt": {
        "pt-BR": "O adjetivo-い 大きい (おおきい) aparece sozinho numa frase. Ele JÁ significa 'é grande' no presente, sem precisar de verbo?"
      },
      "answer": {
        "choices": [
          "Sim, o adjetivo-い já carrega o tempo sozinho",
          "Não, precisa sempre de です ou outro verbo para ter sentido"
        ],
        "correct": "Sim, o adjetivo-い já carrega o tempo sozinho"
      },
      "explanation": {
        "pt-BR": "Esta é a marca registrada do adjetivo-い: ele 'se conjuga' por conta própria. 大きい já é 'é grande'. Você pode acrescentar です para soar polido, mas não é obrigatório."
      },
      "sentence_refs": [
        "sent:tatoeba-13063899"
      ]
    },
    {
      "id": "ex:n5-adjetivos-01-3",
      "type": "cloze",
      "prompt": {
        "pt-BR": "Complete para deixar a descrição mais forte: ＿青いです。 (É muito azul.)"
      },
      "answer": {
        "text": "とても",
        "full": "とても青いです"
      },
      "explanation": {
        "pt-BR": "とても ('muito') vem antes do adjetivo para intensificar. Funciona igual com adjetivo-い e adjetivo-な. O 青い (azul) continua intacto."
      },
      "sentence_refs": []
    },
    {
      "id": "ex:n5-adjetivos-01-4",
      "type": "cloze",
      "prompt": {
        "pt-BR": "きれい é adjetivo-な, então precisa fechar a frase. Complete: きれい＿。 (É bonito(a).)"
      },
      "answer": {
        "text": "です",
        "full": "きれいです"
      },
      "explanation": {
        "pt-BR": "Adjetivos-な não carregam o tempo sozinhos: comportam-se como substantivos e pedem です (ou だ no casual) para o presente. Por isso きれいです = 'é bonito(a)'."
      },
      "sentence_refs": []
    },
    {
      "id": "ex:n5-adjetivos-01-5",
      "type": "production",
      "prompt": {
        "pt-BR": "Diga em japonês 'É muito pequeno.' usando とても, o adjetivo 小さい (pequeno) e a cópula educada です."
      },
      "answer": {
        "text": "とても小さいです。",
        "accept": [
          "とても小さいです",
          "とても小さいです。",
          "とてもちいさいです",
          "とてもちいさいです。"
        ]
      },
      "explanation": {
        "pt-BR": "とても (muito) + 小さい (adjetivo-い 'pequeno', que já carrega o presente) + です (para soar polido). O い do adjetivo NÃO some quando você acrescenta です."
      },
