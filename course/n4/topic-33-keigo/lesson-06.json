  "exercises": [
    {
      "id": "ex:n4-keigo-06-1",
      "type": "recognition",
      "prompt": {
        "pt-BR": "A fórmula 〜ていただけませんか deriva de qual verbo humilde (kenjōgo)?"
      },
      "answer": {
        "choices": [
          "いただく (receber, humilde de もらう)",
          "いらっしゃる (estar/ir/vir, honorífico)",
          "なさる (fazer, honorífico)"
        ],
        "correct": "いただく (receber, humilde de もらう)"
      },
      "explanation": {
        "pt-BR": "〜ていただけませんか vem de いただく ('receber'), o humilde de もらう, colocado no potencial negativo interrogativo: 'não poderia eu receber que você faça...?'. いらっしゃる e なさる são honoríficos (sonkeigo), não humildes."
      },
      "sentence_refs": []
    },
    {
      "id": "ex:n4-keigo-06-2",
      "type": "recognition",
      "prompt": {
        "pt-BR": "Você precisa pedir um favor a um cliente que não é obrigado a ajudar. Qual fórmula soa mais educada?"
      },
      "answer": {
        "choices": [
          "待ってください",
          "お待ちください",
          "待っていただけませんか"
        ],
        "correct": "待っていただけませんか"
      },
      "explanation": {
        "pt-BR": "Para pedir um FAVOR de forma muito educada, 〜ていただけませんか é a mais polida das três. 〜てください é neutro/direto e お〜ください é respeitoso (típico de avisos), mas a pergunta negativa de いただけませんか deixa o interlocutor totalmente livre para topar ou não."
      },
      "sentence_refs": []
    },
    {
      "id": "ex:n4-keigo-06-3",
      "type": "cloze",
      "prompt": {
        "pt-BR": "Complete o pedido educado 'Você poderia me emprestar o telefone?': 電話を貸して＿＿＿＿＿＿。"
      },
      "answer": {
        "text": "いただけませんか",
        "full": "電話を貸していただけませんか"
      },
      "explanation": {
        "pt-BR": "Verbo 貸す (emprestar) na forma て (貸して) + いただけませんか forma o pedido muito educado. O objeto 電話 já está marcado por を."
      },
      "sentence_refs": [
        "sent:tatoeba-124645"
      ]
    },
    {
      "id": "ex:n4-keigo-06-4",
      "type": "sentence_build",
      "prompt": {
        "pt-BR": "Monte 'Você poderia acender a luz, por favor?' com as peças: [いただけませんか] [電気] [つけて] [を]"
      },
      "answer": {
        "order": [
          "電気",
