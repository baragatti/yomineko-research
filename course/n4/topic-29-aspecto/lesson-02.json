{
  "id": "les:n4-aspecto-02",
  "schema_version": "1.0",
  "level": "n4",
  "topic": "top:n4-aspecto",
  "order": 2,
  "title": {
    "pt-BR": "Continuar e prosseguir: 〜続ける, 〜ていく e 〜ていた"
  },
  "description": {
    "pt-BR": "Trata da fase de continuidade. Apresenta 〜続ける (continuar fazendo), 〜ていく (ir fazendo / mudança rumo ao futuro, afastando-se do falante) e 〜ていた (estava fazendo / passado contínuo), formando o eixo da duração da ação no tempo."
  },
  "objectives": [
    {
      "pt-BR": "Dizer que uma ação prossegue ao longo do tempo com 〜続ける (radical do verbo + 続ける)"
    },
    {
      "pt-BR": "Expressar 'ir fazendo' e mudança que avança rumo ao futuro com 〜ていく"
    },
    {
      "pt-BR": "Narrar uma ação ou estado em andamento no passado com 〜ていた (passado contínuo)"
    }
  ],
