{
  "id": "les:n4-condicionais-06",
  "schema_version": "1.0",
  "level": "n4",
  "topic": "top:n4-condicionais",
  "order": 6,
  "title": {
    "pt-BR": "Situações e condições suficientes: 場合は e だけで"
  },
  "description": {
    "pt-BR": "Foca em condições ligadas a circunstâncias específicas. 場合は (\"no caso de / quando\") descreve o que fazer em determinada situação, muito comum em regras e avisos; 〜だけで (\"só com / basta\") indica que uma condição mínima já é suficiente. Inclui vocabulário de objetos e ambientes."
  },
  "objectives": [
    {
      "pt-BR": "Descrever o que fazer em uma situação específica com 場合は ('no caso de / quando')"
    },
    {
      "pt-BR": "Dizer que uma condição mínima já basta com 〜だけで ('só com / basta')"
    },
    {
      "pt-BR": "Reconhecer 場合は em regras, instruções e avisos do dia a dia"
    }
  ],
