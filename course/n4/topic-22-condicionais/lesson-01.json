{
  "id": "les:n4-condicionais-01",
  "schema_version": "1.0",
  "level": "n4",
  "topic": "top:n4-condicionais",
  "order": 1,
  "title": {
    "pt-BR": "Condicional たら: \"se\" e \"quando\""
  },
  "description": {
    "pt-BR": "Apresenta a forma condicional mais versátil e coloquial do japonês, 〜たら, que cobre tanto \"se\" (hipótese) quanto \"quando / depois que\" (sequência no tempo). A oração com たら traz a condição; a segunda oração, o resultado. Base para todas as construções condicionais do tópico."
  },
  "objectives": [
    {
      "pt-BR": "Formar 〜たら a partir do passado casual do verbo (forma た → たら)"
    },
    {
      "pt-BR": "Usar 〜たら como condicional flexível, cobrindo tanto 'se' (hipótese) quanto 'quando / depois que' (sequência no tempo)"
    },
    {
      "pt-BR": "Montar frases A→B do cotidiano: condição com たら na primeira oração, resultado na segunda"
    },
    {
      "pt-BR": "Reconhecer os kanji 体 (corpo) e 力 (força)"
    }
  ],
