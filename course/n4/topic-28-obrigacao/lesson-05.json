{
  "id": "les:n4-obrigacao-05",
  "schema_version": "1.0",
  "level": "n4",
  "topic": "top:n4-obrigacao",
  "order": 5,
  "title": {
    "pt-BR": "Não precisar fazer: なくて e なくてもいい"
  },
  "description": {
    "pt-BR": "Fecha o tópico com a forma て da negação, 〜なくて, que liga orações negativas (causa ou estado). A partir dela chega-se a 〜なくてもいい (não precisa fazer), a permissão para não realizar a ação, o complemento natural da obrigação. Vocabulário variado de revisão."
  },
  "objectives": [
    {
      "pt-BR": "Formar a forma て negativa 〜なくて a partir da negativa 〜ない"
    },
    {
      "pt-BR": "Ligar duas orações com 〜なくて (causa ou estado negativo)"
    },
    {
      "pt-BR": "Dizer que algo NÃO precisa ser feito com 〜なくてもいい / 〜なくていい"
    }
  ],
