{
  "id": "les:n4-forma-simples-06",
  "schema_version": "1.0",
  "level": "n4",
  "topic": "top:n4-forma-simples",
  "order": 6,
  "title": {
    "pt-BR": "Sufixos e intensificadores: 〜代 e 真っ"
  },
  "description": {
    "pt-BR": "Apresenta dois recursos de formação de palavras. O sufixo 〜代 (だい) indica o custo ou a taxa de algo (電気代 = \"conta de luz\", タクシー代 = \"o valor do táxi\"); o prefixo 真（ま／まっ／まん）intensifica cores, formas e posições (真っ赤 = \"vermelho vivo\", 真ん中 = \"bem no meio\"). Vocabulário de movimento, sorte e ações úteis com esses moldes."
  },
  "objectives": [
    {
      "pt-BR": "Formar palavras de custo com 〜代 grudando o sufixo a um substantivo de serviço ou item"
    },
    {
      "pt-BR": "Intensificar cores, formas e posições com o prefixo 真（ま／まっ／まん）"
    },
    {
      "pt-BR": "Reconhecer e usar o vocabulário de movimento, sorte e ações úteis da lição"
    }
  ],
