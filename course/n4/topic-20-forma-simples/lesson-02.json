  "exercises": [
    {
      "id": "ex:n4-forma-simples-02-1",
      "type": "recognition",
      "prompt": {
        "pt-BR": "Seu amigo diz この料理おいしいじゃないか ao provar a comida. O que ele está fazendo?"
      },
      "answer": {
        "choices": [
          "Negando que a comida seja gostosa",
          "Elogiando a comida e buscando sua concordância ('tá uma delícia, né?')",
          "Perguntando se a comida é cara"
        ],
        "correct": "Elogiando a comida e buscando sua concordância ('tá uma delícia, né?')"
      },
      "explanation": {
        "pt-BR": "Apesar do formato negativo, じゃないか aqui é uma constatação POSITIVA com emoção: um elogio que pede concordância, não uma dúvida sobre o sabor."
      },
      "sentence_refs": [
        "sent:gen-5b8afca2e28a"
      ]
    },
    {
      "id": "ex:n4-forma-simples-02-2",
      "type": "recognition",
      "prompt": {
        "pt-BR": "じゃないか e ではないか se diferenciam principalmente em quê?"
      },
      "answer": {
        "choices": [
          "No significado: uma é positiva, a outra negativa",
          "No registro: じゃないか é a contração casual de ではないか, mais neutra",
          "No tempo verbal que exigem"
        ],
        "correct": "No registro: じゃないか é a contração casual de ではないか, mais neutra"
      },
      "explanation": {
        "pt-BR": "Têm o mesmo sentido (buscar concordância / marcar constatação). じゃ é só a contração coloquial de では, igual ao português falado que encurta as sílabas."
      },
      "sentence_refs": []
    },
    {
      "id": "ex:n4-forma-simples-02-3",
      "type": "cloze",
      "prompt": {
        "pt-BR": "Complete para dizer 'Tô com a sensação de que a primavera já chegou.': もう春が来た＿＿＿だ。"
      },
      "answer": {
        "text": "って感じ",
        "full": "もう春が来たって感じだ"
      },
      "explanation": {
        "pt-BR": "って感じ transmite a impressão/vibe de algo ('tipo assim'). Vem depois da forma simples 来た (chegou) e fecha com だ no casual."
      },
      "sentence_refs": [
        "sent:gen-238f14601cdc"
      ]
    },
    {
      "id": "ex:n4-forma-simples-02-4",
      "type": "sentence_build",
      "prompt": {
        "pt-BR": "Monte 'Eu vivo dizendo isso, ué!' com as peças: [じゃないか] [いつも] [言ってる]"
      },
      "answer": {
        "order": [
          "いつも",
          "言ってる",
          "じゃないか"
        ],
        "text": "いつも言ってるじゃないか。"
      },
      "explanation": {
        "pt-BR": "いつも (sempre) + 言ってる (estar dizendo, casual) + じゃないか (constatação com leve protesto: 'ué!'). A expressão fecha a frase."
      },
      "sentence_refs": [
        "sent:tatoeba-228724"
      ]
    },
    {
      "id": "ex:n4-forma-simples-02-5",
      "type": "production",
      "prompt": {
        "pt-BR": "Você reconhece o Tom de longe e quer soltar, em tom casual de descoberta, 'Ora, não é o Tom?!'. Use o nome トム e a expressão neutra de constatação."
      },
      "answer": {
        "text": "トムではないか。",
        "accept": [
          "トムではないか",
          "トムではないか。",
          "トムじゃないか",
          "トムじゃないか。"
        ]
      },
      "explanation": {
        "pt-BR": "トム + ではないか marca a descoberta ('ora, não é o Tom?!'). A versão ainda mais casual seria トムじゃないか; a mesma ideia, só mais coloquial."
      },
