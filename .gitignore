# --- Python ---
.venv/
venv/
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# --- Canonical DB (binary, regenerable from scripts + datasets) ---
db/*.sqlite
db/*.sqlite-wal
db/*.sqlite-shm
db/*.db

# --- Raw downloaded datasets (large; provenance tracked in design/sources.md) ---
# We keep manifests/checksums + derived extracts in git, NOT the multi-hundred-MB raws.
research/datasets/**
# re-include DIRECTORIES so git descends (else the file negations below can't match):
!research/datasets/**/
!research/datasets/.gitkeep
!research/datasets/**/MANIFEST.md
!research/datasets/**/*.sha256
!research/datasets/**/*.checksums

# --- OS / editor noise ---
.DS_Store
Thumbs.db
*.swp
.idea/
.vscode/

# --- Scratch ---
tmp/
scratch/
*.log

# --- Claude Code preview helper (local dev convenience) ---
.claude/launch.json

# Regenerable split-group working dirs (rebuilt by split_groups.py from batch_*.json)
research/derived/*_groups/
research/_n3_vocab_todo.json
research/_n3_kanji_todo.json
research/_n3_grammar_seed.json
research/_n3_lesson_inputs.json
research/datasets/n3_grammar_hanabira.json
research/derived/n3_dissect/
research/_n3_lesson_inputs_b.json
research/derived/_n3_lessons_b_out.json
research/derived/_n3_reauthor_out.json
research/derived/_n3_contaminated.json
research/derived/_accent_automap.json
research/_*.py
research/_*.txt
research/_tmp_*.json
research/_n3_lessons_6_11.json
research/derived/tr/
research/derived/reauthor/
