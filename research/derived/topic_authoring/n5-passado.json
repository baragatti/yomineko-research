  "grammar": [
    {
      "key": "gp-32",
      "pattern": "だった・でした",
      "label": "era / foi (passado de です → だった・でした)",
      "explanation": "だった e でした são o passado do verbo \"ser/estar\" (a cópula です／だ). Usamos para dizer que algo \"era\" ou \"foi\" assim antes, ligando um substantivo ou adjetivo-な a um estado anterior: 学生でした = \"Eu era estudante\"; 元気だった = \"Eu estava bem\". でした é a ver…",
      "candidate_sentences": [
        {
          "slug": "sent:tatoeba-83696",
          "jp": "雰囲気がいやだった。",
          "pt": "O clima estava desagradável."
        },
        {
          "slug": "sent:tatoeba-78700",
          "jp": "来る日も来る日も雨だった。",
          "pt": "Chovia dia após dia."
        }
      ]
    },
    {
      "key": "gp-34",
      "pattern": "じゃなかった",
      "label": "じゃなかった (negativo passado de substantivos e な-adjetivos)",
      "explanation": "じゃなかった é o negativo do passado, no registro casual, para frases com substantivo ou adjetivo-な. Significa \"não era\" / \"não foi\". É o par passado de じゃない (negativo do presente). Use para dizer que algo NÃO era verdade num momento anterior: 学生…",
      "candidate_sentences": [
        {
          "slug": "sent:tatoeba-10515932",
          "jp": "聞くんじゃなかった。",
          "pt": "Eu não devia ter perguntado."
        }
      ]
    },
    {
      "key": "na",
      "pattern": "な",
      "label": "partícula な (proibição/ênfase masculina)",
      "explanation": "A partícula final な (na) tem dois usos principais. Ligada à forma de dicionário de um verbo, forma uma proibição forte: 行くな = \"não vá / nem pense em ir\". Sozinha, no fim da frase, é uma partícula de ênfase ou autoconfirmação, parecida com ね…",
      "candidate_sentences": [
        {
          "slug": "sent:tatoeba-11571318",
          "jp": "さすがだな！",
          "pt": "Você é demais!"
        },
        {
          "slug": "sent:tatoeba-11500016",
          "jp": "見てみたいな。",
          "pt": "Queria ver isso."
        },
        {
          "slug": "sent:tatoeba-77191",
          "jp": "話しかけるな。",
          "pt": "Não fale comigo."
        },
        {
          "slug": "sent:tatoeba-173403",
          "jp": "行きたくないのなら、行くな。",
          "pt": "Se você não quer ir, não vá."
        }
      ]
    },
    {
      "key": "naa",
      "pattern": "なあ",
      "label": "partícula final なあ (admiração/desejo)",
      "explanation": "なあ (naa, com vogal alongada) é uma partícula que vai no fim da frase para expressar emoção: admiração, alívio, saudade, vontade ou um pensamento dito em voz alta. Equivale a interjeições do português como \"...hein\", \"nossa...\", \"ah, que...\"…",
      "candidate_sentences": [
        {
          "slug": "sent:tatoeba-3488338",
          "jp": "いいなあ。",
          "pt": "Que inveja!"
        },
        {
          "slug": "sent:tatoeba-77673",
          "jp": "冷たいなあ。",
          "pt": "Que frieza..."
        },
        {
          "slug": "sent:tatoeba-203366",
          "jp": "タフだなあ。",
          "pt": "Nossa, que durão..."
        },
        {
          "slug": "sent:tatoeba-226045",
          "jp": "キツイなあ。",
          "pt": "Nossa, que duro..."
        },
        {
          "slug": "sent:tatoeba-229334",
          "jp": "いい天気だなあ。",
          "pt": "Que tempo bom, hein!"
        },
        {
          "slug": "sent:tatoeba-1202184",
          "jp": "車があればなあ。",
          "pt": "Ah, se eu tivesse um carro..."
        }
      ]
    },
    {
      "key": "ne",
      "pattern": "ね",
      "label": "partícula ね (confirmação/concordância)",
      "explanation": "ね é uma partícula final de frase que busca a concordância ou confirmação do interlocutor, parecida com o nosso \"né?\", \"não é?\", \"viu?\". Suaviza a fala e cria conexão, mostrando que você espera que a outra pessoa compartilhe a mesma opinião …",
      "candidate_sentences": [
        {
          "slug": "sent:tatoeba-13063899",
          "jp": "大きいね。",
          "pt": "É grande, né?"
        },
        {
          "slug": "sent:tatoeba-11532911",
          "jp": "わがままね。",
          "pt": "Você é egoísta, né."
        },
        {
          "slug": "sent:tatoeba-8608115",
          "jp": "後で話そうね。",
          "pt": "A gente conversa depois, tá?"
        },
        {
          "slug": "sent:tatoeba-200577",
          "jp": "とても大きいね。",
          "pt": "É bem grande, né?"
        }
      ]
    },
    {
      "key": "yo",
      "pattern": "よ",
      "label": "partícula final よ (asserção / informação nova)",
      "explanation": "よ é uma partícula que vai no fim da frase para afirmar algo com convicção, chamar a atenção do ouvinte ou passar uma informação que você acredita que ele ainda não sabe. Dá o tom de \"olha, vou te avisar/te contar: ...\" ou \"pode acreditar\". …",
      "candidate_sentences": []
    }
  ],
