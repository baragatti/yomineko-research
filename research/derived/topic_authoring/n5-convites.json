  "grammar": [
    {
      "key": "gp-50",
      "pattern": "たほうがいい",
      "label": "é melhor (fazer), (～たほうがいい)",
      "explanation": "～たほうがいい serve para dar conselho ou recomendação: \"é melhor (você) fazer X\". Ele compara duas opções (ほう = \"lado/opção\") e diz que a de fazer aquilo é a boa (いい = \"bom\"). Ex.: 早く寝たほうがいい = \"É melhor você dormir cedo\". Soa como uma sugestão am…",
      "candidate_sentences": [
        {
          "slug": "sent:tatoeba-216787",
          "jp": "さっさと行ったほうがいい。",
          "pt": "É melhor a gente ir logo."
        },
        {
          "slug": "sent:tatoeba-3366998",
          "jp": "もっと休みをとったほうがいい。",
          "pt": "É melhor você descansar mais."
        }
      ]
    },
    {
      "key": "issho-ni",
      "pattern": "一緒に（いっしょに）",
      "label": "juntos / junto com (一緒に / いっしょに)",
      "explanation": "一緒に（いっしょに）é um advérbio que significa \"juntos\", \"em conjunto\", \"junto com (alguém)\". Indica que duas ou mais pessoas fazem a mesma ação ao mesmo tempo. Aparece muito em convites e combinados: \"vamos juntos\", \"vamos comer juntos\".",
      "candidate_sentences": [
        {
          "slug": "sent:tatoeba-774809",
          "jp": "一緒に来るの？",
          "pt": "Você vem junto?"
        },
        {
          "slug": "sent:tatoeba-190532",
          "jp": "一緒に行かない？",
          "pt": "Não quer ir junto?"
        },
        {
          "slug": "sent:tatoeba-190548",
          "jp": "一緒に行きます。",
          "pt": "Eu vou junto."
        },
        {
          "slug": "sent:tatoeba-774810",
          "jp": "一緒に来ますか？",
          "pt": "Você vem junto?"
        }
      ]
    },
    {
      "key": "masen-ka",
      "pattern": "～ませんか",
      "label": "convite \"não quer...?\" (〜ませんか)",
      "explanation": "É a forma educada de convidar alguém a fazer algo com você, tipo \"vamos...?\" ou \"você não quer...?\". Soa gentil porque, perguntando de forma negativa, deixa o ouvinte livre para aceitar ou recusar sem pressão. Ex.: 一緒（いっしょ）に映画（えいが）を見（み）ませんか…",
      "candidate_sentences": [
        {
          "slug": "sent:tatoeba-172871",
          "jp": "今からドライブに行きませんか。",
          "pt": "Que tal a gente dar uma volta de carro agora?"
        },
        {
          "slug": "sent:gen-4e948f2f75b0",
          "jp": "今晩うちに来ませんか",
          "pt": "Você não quer vir à minha casa hoje à noite?"
        },
        {
          "slug": "sent:gen-24bb23e4256e",
          "jp": "ちょっと休みませんか",
          "pt": "Vamos descansar um pouco?"
        }
      ]
    },
    {
      "key": "mashou",
      "pattern": "～ましょう",
      "label": "vamos fazer (〜ましょう)",
      "explanation": "Expressa \"vamos (fazer algo)\": uma sugestão ou proposta de fazer algo junto, ou a aceitação de um convite. Também serve para se oferecer a fazer algo. Ex.: 始（はじ）めましょう = \"Vamos começar\"; 行（い）きましょう = \"Vamos (lá)\".",
      "candidate_sentences": [
        {
          "slug": "sent:tatoeba-139208",
          "jp": "行きましょう。",
          "pt": "Vamos!"
        },
        {
