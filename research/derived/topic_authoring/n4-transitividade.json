  "grammar": [
    {
      "key": "gp-64",
      "pattern": "他動詞・自動詞",
      "label": "verbos transitivos e intransitivos (他動詞・自動詞)",
      "explanation": "O japonês tem muitos pares de verbos relacionados: o transitivo (他動詞, tadōshi) descreve alguém fazendo algo a um objeto, e o intransitivo (自動詞, jidōshi) descreve algo que acontece ou muda por si. Ex.: ドアを開ける (\"eu abro a porta\", transitivo) …",
      "candidate_sentences": [
        {
          "slug": "sent:tatoeba-10511481",
          "jp": "それは、他動詞です。",
          "pt": "Esse é um verbo transitivo."
        },
        {
          "slug": "sent:tatoeba-11619528",
          "jp": "この動詞は、他動詞にも自動詞にもなる。",
          "pt": "Este verbo pode ser tanto transitivo quanto intransitivo."
        },
        {
          "slug": "sent:gen-eeb95dda0812",
          "jp": "ドアが開く",
          "pt": "A porta abre."
        },
        {
          "slug": "sent:gen-5c7d35fc5548",
          "jp": "ドアを開ける",
          "pt": "Abrir a porta."
        },
        {
          "slug": "sent:gen-867d5c2e8dc3",
          "jp": "電気を消した",
          "pt": "Apaguei a luz."
        },
        {
          "slug": "sent:gen-f490f11e55b3",
          "jp": "電気が消えた",
          "pt": "A luz apagou."
        }
      ]
    },
    {
      "key": "tadoushi-jidoushi",
      "pattern": "他動詞 & 自動詞（たどうし & じどうし）",
      "label": "verbos transitivos e intransitivos (他動詞・自動詞)",
      "explanation": "O japonês distingue pares de verbos: o 他動詞 (transitivo) descreve uma ação que alguém faz sobre um objeto, e o 自動詞 (intransitivo) descreve algo que acontece por si só, sem agente direto. Ex.: ドアを開ける ('eu abro a porta') usa o transitivo 開ける, …",
      "candidate_sentences": [
        {
          "slug": "sent:gen-83f74d460da8",
          "jp": "母が窓を閉めました",
          "pt": "Minha mãe fechou a janela."
        },
        {
          "slug": "sent:gen-596fab7713a5",
          "jp": "私はドアを開けました",
          "pt": "Eu abri a porta."
        },
        {
          "slug": "sent:gen-9826aa27f5d5",
          "jp": "風でドアが開きました",
          "pt": "A porta abriu com o vento."
        },
        {
          "slug": "sent:gen-63c0e6f49c27",
          "jp": "弟が電気を消しました",
          "pt": "Meu irmão mais novo apagou a luz."
        },
        {
          "slug": "sent:gen-1204f5348d39",
          "jp": "急に電気が消えました",
          "pt": "A luz apagou de repente."
        }
      ]
    }
  ],
