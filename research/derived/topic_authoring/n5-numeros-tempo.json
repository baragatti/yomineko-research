  "grammar": [
    {
      "key": "gp-43",
      "pattern": "たくさん",
      "label": "たくさん (muito / muitos, em quantidade)",
      "explanation": "たくさん significa \"muito\" no sentido de QUANTIDADE ou número grande: \"muitas pessoas\", \"comi muito\", \"há muitos livros\". É um advérbio (e também quantificador) usado para coisas contáveis ou volume, diferente de とても, que mede a INTENSIDADE de …",
      "candidate_sentences": [
        {
          "slug": "sent:tatoeba-122326",
          "jp": "日本語を話せるアメリカ人がたくさんいる。",
          "pt": "Há muitos americanos que sabem falar japonês."
        }
      ]
    },
    {
      "key": "gp-44",
      "pattern": "くらい ①",
      "label": "くらい / ぐらい (aproximadamente, quantidade)",
      "explanation": "くらい (também pronunciado ぐらい) é uma partícula que indica quantidade APROXIMADA: \"mais ou menos\", \"cerca de\", \"por volta de\". Vem depois de um número ou de uma expressão de quantidade/tempo para tirar a precisão, como em \"uns três\", \"umas dua…",
      "candidate_sentences": [
        {
          "slug": "sent:tatoeba-200413",
          "jp": "どのくらい高い？",
          "pt": "Qual é a altura dele? / Quão alto é?"
        },
        {
          "slug": "sent:tatoeba-190376",
          "jp": "一千万円くらいかな？",
          "pt": "Será que é uns dez milhões de ienes?"
        },
        {
          "slug": "sent:tatoeba-141433",
          "jp": "千人くらいの人がいた。",
          "pt": "Havia cerca de mil pessoas."
        },
        {
          "slug": "sent:tatoeba-190227",
          "jp": "一年前くらい前に来ました。",
          "pt": "Vim por volta de um ano atrás."
        },
        {
          "slug": "sent:tatoeba-149104",
          "jp": "車でどれくらいかかりますか。",
          "pt": "Quanto tempo leva de carro?"
        }
      ]
    }
  ],
